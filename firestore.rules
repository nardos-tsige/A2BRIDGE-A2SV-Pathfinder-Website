rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    // Check if the user is authenticated
    function isAuthenticated() {
       return request.auth != null;
    }
    
    // Check if user owns the resource (for user-owned documents)
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Validate required fields exist
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    
    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // Verify UID hasn't been tampered with on create
    function uidUnchanged() {
       return !('uid' in request.resource.data) ||
         request.resource.data.uid == request.auth.uid;
    }
    
    // Ensure uid field is not modified on update
    function uidNotModified() {
       return !('uid' in request.resource.data) ||
         request.resource.data.uid == resource.data.uid;
    }
    
    // Validate that the document hasn't changed in the fields that are not allowed to be changed
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'bio', 'github', 'linkedin', 'university', 'leetcode', 'problemsSolved', 'currentStreak', 'daysActive', 'lastActiveDate', 'createdAt']) &&
             data.uid is string && data.uid.size() > 0 && data.uid.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 150 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 1000)) &&
             (!('github' in data) || (data.github is string && data.github.size() <= 200)) &&
             (!('linkedin' in data) || (data.linkedin is string && data.linkedin.size() <= 200)) &&
             (!('university' in data) || (data.university is string && data.university.size() <= 150)) &&
             (!('leetcode' in data) || (data.leetcode is string && data.leetcode.size() <= 200)) &&
             data.problemsSolved is number && data.problemsSolved >= 0 &&
             data.currentStreak is number && data.currentStreak >= 0 &&
             data.daysActive is number && data.daysActive >= 0 &&
             (!('lastActiveDate' in data) || (data.lastActiveDate is string && data.lastActiveDate.size() <= 20)) &&
             data.createdAt is timestamp;
    }

    function isValidActivity(data) {
      return hasOnlyAllowedFields(['title', 'description', 'type', 'timestamp']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 150 &&
             data.description is string && data.description.size() >= 0 && data.description.size() <= 500 &&
             data.type is string && data.type.size() > 0 && data.type.size() <= 50 &&
             data.timestamp is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged();
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() && areImmutableFieldsUnchanged(['createdAt']);
      allow delete: if isOwner(userId);

      match /activities/{activityId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidActivity(request.resource.data);
        allow update: if isOwner(userId) && isValidActivity(request.resource.data) && areImmutableFieldsUnchanged(['timestamp', 'type']);
        allow delete: if isOwner(userId);
      }
    }
  }
}
